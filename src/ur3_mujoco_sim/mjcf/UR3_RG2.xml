    <geom contype="0" conaffinity="0"/>
    <joint damping="10" frictionloss="0.01" armature="0.1"/>
    <general gaintype="fixed" biastype="affine"/>
      
    <default class="d435i">
      <material specular="0" shininess="0.25"/>
      <default class="visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0" mass="0"/>
      </default>
      <default class="collision">
        <geom group="3" type="mesh" mass="0"/>
      </default>
    </default>
  </default>

