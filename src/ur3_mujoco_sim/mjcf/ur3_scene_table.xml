<mujoco model="ur3_scene_table">
  <!--
    Robot kinematics: UR3_RG2.xml (RG2 CAD / non-official DH). Joint names match ROS, but link
    frames and axes differ from ur_description / ur3_mujoco_fixed.urdf.xacro — TF from robot_state_publisher
    will not match MuJoCo body poses one-for-one.
  -->
  <include file="UR3_RG2.xml"/>
  <option gravity="0 0 -9.81"/>
  <!-- Camera framing for the MuJoCo viewer -->
  <statistic center="0.35 0 0.65" extent="1.8"/>

  <visual>
    <headlight diffuse="0.65 0.65 0.65" ambient="0.2 0.2 0.22" specular="0.2 0.2 0.2"/>
    <rgba haze="0.12 0.18 0.28 1"/>
    <global azimuth="140" elevation="-22"/>
    <!-- Show per-body axis frames clearly in MuJoCo viewer (visual only, no collision impact). -->
    <scale framelength="0.08" framewidth="0.004"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <!-- Sky gradient + checkered floor material -->
    <texture type="skybox" builtin="gradient" rgb1="1.0 1.0 1.0" rgb2="0.98 0.95 0.88" width="512" height="3072"/>
    <!-- For file-based textures, do not force width/height that can conflict with
         actual image dimensions and crash MuJoCo loader. -->
    <texture type="2d" name="ground_tex" file="../meshes/tile.png"/>
    <material name="ground_mat" texture="ground_tex" texuniform="true" texrepeat="1 1" reflectance="0" rgba="0.5 0.5 0.5 1"/>
    <mesh name="table_mesh" file="../meshes/table.stl" scale="0.001 0.001 0.001"/>
    <mesh name="table_upper_mesh" file="../meshes/table_upper.stl" scale="0.001 0.001 0.001"/>
    <mesh name="cylinder_1_mesh" file="../meshes/cylinder_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="cylinder_2_mesh" file="../meshes/cylinder_2.stl" scale="0.001 0.001 0.001"/>
    <mesh name="square_1_mesh" file="../meshes/square_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="cylinder_1_col_mesh" file="../meshes/cylinder_1_col.stl" scale="0.001 0.001 0.001"/>
    <mesh name="cylinder_2_col_mesh" file="../meshes/cylinder_2_col.stl" scale="0.001 0.001 0.001"/>
    <mesh name="square_1_col_mesh" file="../meshes/square_1_col.stl" scale="0.001 0.001 0.001"/>
    <mesh name="table_upper_col_mesh" file="../meshes/table_upper.stl" scale="0.001 0.001 0.001"/>
    <material name="table_mesh_mat" rgba="0.42 0.30 0.18 1" specular="0.3" shininess="0.2"/>
    <material name="table_green" rgba="0.2 0.7 0.3  1" shininess="0" specular="0"/>
    <material name="aluminum_1_mat" rgba="0.7 0.7 0.7 1" shininess="1" specular="1" reflectance="1" />
    <material name="copper_mat" rgba="0.80 0.58 0.35 1" shininess="1" specular="1" reflectance="1" />
    <material name="aluminum_2_mat" rgba="0.8 0.8 0.8 1" shininess="1" specular="1" reflectance="1" />
  </asset>

  <!-- Scene: lights, floor, table (merged with robot worldbody from include) -->
  <worldbody>
    <light name="key" pos="1.0 0.6 1.2" dir="-0.6 -0.35 -0.72" directional="true" diffuse="0.75 0.92 0.88" specular="0.3 0.3 0.3"/>
    <light name="fill" pos="-0.8 0.9 0.9" dir="0.45 -0.55 -0.7" directional="true" diffuse="0.35 0.38 0.45"/>
    <light name="rim" pos="0.0 1.0 -1.5" dir="0.0 -0.5 1.0" directional="true" diffuse="0.4 0.4 0.4" specular="0.5 0.5 0.5"/>

    <!-- Large floor slab (xy plane near z=0) -->
    <geom name="scene_floor" type="box" pos="0 0 -0.002" size="5 5 0.002" material="ground_mat" 
          condim="4" friction="1 0.02 0.001" contype="1" conaffinity="1"/>

    <!-- Table mesh in front of the robot (+X). -->
    <body name="table" pos="-0.441108 -0.28111 0">
      <geom
        name="table_geom_vis"
        type="mesh"
        mesh="table_mesh"
        pos="0 0 0"
        euler="0 0 -1.57079632679"
        material="aluminum_2_mat"
        contype="0"
        conaffinity="0"/>
      <!-- table_upper: visual only (contype 0). Tabletop physics uses table_col box below. -->
      <geom
        name="table_upper_geom_vis"
        type="mesh"
        mesh="table_upper_mesh"
        pos="0 0 0.78"
        euler="0 0 1.57079632679"
        material="table_green"
        friction="0.9 0.02 0.001"
        contype="0"
        conaffinity="0"/>
      <geom name="table_col" type="box" size="1 1 0.79" pos="0 0 0" euler="0 0 -1.57079632679"
            condim="4" friction="0.1 0.02 0.001" solimp="0.95 0.99 0.001 0.5 2" solref="0.01 1"
            contype="1" conaffinity="1" rgba="1 1 1 0"/>
    </body>

    <!-- Objects on/near the table -->

    <body name="cylinder_1_obj" pos="-0.3 0.08 0.9">
      <!-- Do not inherit UR3_RG2 default joint damping=10 (would heavily damp free motion). -->
      <joint type="free" damping="0" frictionloss="0.0001" armature="0.0001"/>
      <inertial pos="0 0 0.0185" mass="0.059747" diaginertia="10.676195e-06 10.676194e-06 7.761395e-06"/>
      <geom name="cylinder_1_vis" type="mesh" mesh="cylinder_1_mesh" pos="0 0 0" material="aluminum_1_mat"
            contype="0" conaffinity="0"/>
      <geom name="cylinder_1_col" type="mesh" mesh="cylinder_1_col_mesh" pos="0 0 0"
            condim="4" friction="0.2 0.02 0.001" solimp="0.95 0.99 0.001 0.5 2" solref="0.01 1"
            contype="1" conaffinity="1" rgba="1 1 1 0"/>
    </body>

    <body name="cylinder_2_obj" pos="-0.3 -0.08 0.9">
      <joint type="free" damping="0.001" frictionloss="0.0001" armature="0.0001"/>
      <inertial pos="0 0 0.010337" mass="0.04781" diaginertia="7.401e-06 7.401e-06 9.390e-06"/>
      <geom name="cylinder_2_vis" type="mesh" mesh="cylinder_2_mesh" pos="0 0 0" material="copper_mat"
            contype="0" conaffinity="0"/>
      <geom name="cylinder_2_col" type="mesh" mesh="cylinder_2_col_mesh" pos="0 0 0"
            condim="4" friction="0.2 0.02 0.001" solimp="0.95 0.99 0.001 0.5 2" solref="0.01 1"
            contype="1" conaffinity="1" rgba="1 1 1 0"/>
    </body>

    <body name="square_1_obj" pos="-0.22 0.08 0.9">
      <joint type="free" damping="0.001" frictionloss="0.0001" armature="0.0001"/>
      <inertial pos="-0.007225 0 0.01" mass="0.060153" diaginertia="4.291e-06 1.339e-05 1.334e-05"/>
      <geom name="square_1_vis" type="mesh" mesh="square_1_mesh" pos="0 0 0" material="aluminum_2_mat"
            contype="0" conaffinity="0"/>
      <geom name="square_1_col" type="mesh" mesh="square_1_col_mesh" pos="0 0 0"
            condim="4" friction="0.2 0.02 0.001" solimp="0.95 0.99 0.001 0.5 2" solref="0.01 1"
            contype="1" conaffinity="1" rgba="1 1 1 0"/>
    </body>

  </worldbody>

  <!-- Module_1_Plate welds (names must match mujoco_ros2_simulation); bodies come from UR3_RG2.xml include -->
  <equality>
    <!-- Initial pose: welded to world at Module_1_Plate default body position [-0.3, -0.05, 0.99] -->
    <!-- Stiff world hold: softer solref lets the plate creep at startup (timestep 0.002). -->
    <weld name="module_1_plate_world" body1="Module_1_Plate" solref="0.001 1" active="true"/>
    <!-- Runtime attachment to gripper Case_Base via /mujoco/weld/module_1_plate_attach_case_base -->
    <weld name="module_1_plate_case_base" body1="Module_1_Plate" body2="Case_Base" solref="0.001 1" active="false"/>
  </equality>

  <contact>
    <exclude body1="Module_1_Plate" body2="Case_Base"/>
  </contact>

</mujoco>
